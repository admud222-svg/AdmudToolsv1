{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.melonbp_brp.ballerinolololo.attack": {
      "states": {
        "default": {
          "transitions": [
            {
              "active": "variable.attack_time > 0 && (!query.has_property('melonbp_brp:laser_attack') || !query.property('melonbp_brp:laser_attack'))"
            }
          ]
        },
        "active": {
          "animations": ["attack"],
          "transitions": [{ "default": "query.all_animations_finished" }]
        }
      }
    },
    "controller.animation.melonbp_brp.ballerinolololo.laser_attack": {
      "states": {
        "default": {
          "transitions": [
            {
              "active": "(query.has_property('melonbp_brp:laser_attack') && query.property('melonbp_brp:laser_attack'))"
            }
          ]
        },
        "active": {
          "animations": ["attack2"],
          "transitions": [{ "default": "query.all_animations_finished" }]
        }
      }
    }
  }
}
