{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.melonbp_brp.cocofantoelefanto.move": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": ["idle"],
          "transitions": [{ "walking": "q.ground_speed > 0.1" }],
          "blend_transition": 0.2
        },
        "walking": {
          "animations": ["walk"],
          "transitions": [{ "idle": "q.ground_speed < 0.1" }],
          "blend_transition": 0.2
        }
      }
    },
    "controller.animation.melonbp_brp.cocofantoelefanto.attack": {
      "states": {
        "default": {
          "transitions": [{ "active": "variable.attack_time > 0" }],
          "animations": ["controller.move", "look_at_target"]
        },
        "active": {
          "animations": ["attack"],
          "blend_transition": 0.2,
          "transitions": [{ "default": "query.all_animations_finished" }]
        }
      }
    }
  }
}
